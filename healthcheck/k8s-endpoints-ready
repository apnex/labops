#!/bin/bash
## module: healthcheck/k8s-endpoints-ready
## purpose: block until a Service has at least one READY endpoint address
##          (the Service is reachable — a backing pod is Ready and registered).
##          Gate service-backed dependencies (e.g. admission webhooks) on this
##          before invoking them.
## inputs:  $1=SERVICE $2=NAMESPACE (or SERVICE/NAMESPACE env); WAIT_TIMEOUT (0=unbounded, default 0)
## needs:   -
# for a given service, checks that at least one endpoint address is READY

## defaults
VAR_SLEEP=5
WAIT_TIMEOUT="${WAIT_TIMEOUT:-0}"
ELAPSED=0
if [[ -n $1 ]]; then
	SERVICE=$1
fi
if [[ -n $2 ]]; then
	NAMESPACE=$2
fi

function getReadyAddresses {
	## .subsets[].addresses are READY backends; notReadyAddresses are excluded
	kubectl -n "${NAMESPACE}" get endpoints "${SERVICE}" \
		-o jsonpath='{.subsets[*].addresses[*].ip}' 2>/dev/null
}

if [[ -n ${SERVICE} ]]; then
	ALIVE=0
	while [[ $ALIVE == 0 ]]; do
		ADDRESSES=$(getReadyAddresses)

		## ready once at least one READY address is registered
		if [[ -n ${ADDRESSES} ]]; then
			ALIVE=1
			break
		fi

		printf "%s\n" "[ K8S/ENDPOINTS-READY ] SERVICE [ ${NAMESPACE}/${SERVICE} ] no READY endpoints yet.. sleep ${VAR_SLEEP}" 1>&2
		sleep "${VAR_SLEEP}"
		ELAPSED=$((ELAPSED + VAR_SLEEP))
		if [[ ${WAIT_TIMEOUT} -gt 0 && ${ELAPSED} -ge ${WAIT_TIMEOUT} ]]; then
			printf "%s\n" "[ K8S/ENDPOINTS-READY ] ERROR: ${NAMESPACE}/${SERVICE} no READY endpoints after ${WAIT_TIMEOUT}s" 1>&2
			exit 1
		fi
	done
	printf "%s\n" "[ K8S/ENDPOINTS-READY ] SERVICE [ ${NAMESPACE}/${SERVICE} ] is REACHABLE !!" 1>&2
else
	printf "%s\n" "[ K8S/ENDPOINTS-READY ] ERROR: No SERVICE defined" 1>&2
	exit 1
fi
