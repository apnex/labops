#!/bin/bash
## module: storage/install
## purpose: deploy rancher local-path provisioner + three StorageClasses:
##          standard (Retain, default) + ephemeral (Delete) for dynamic provisioning,
##          local-path-static (no-provisioner, Retain) for operator-authored PVs
## inputs:  KUBECONFIG, LABOPS_ROOT
## needs:   healthcheck/k8s-local

## must run as root; restore /usr/local/bin in PATH (RHEL sudo strips it)
[[ ${EUID:-$(id -u)} -eq 0 ]] || { echo "must be run as root" >&2; exit 1; }
export PATH="/usr/local/sbin:/usr/local/bin:${PATH}"

## ── labops module resolver ───────────────────────────────────────────
LABOPS_BASE="${LABOPS_BASE:-https://labops.sh}"
command -v run >/dev/null 2>&1 || run() {
	local module="$1"; shift
	if [[ -n "${LABOPS_ROOT:-}" && -f "${LABOPS_ROOT}/${module}" ]]; then
		bash "${LABOPS_ROOT}/${module}" "$@"
	else
		curl -fsSL "${LABOPS_BASE}/${module}" | bash -s -- "$@"
	fi
}

## wait for the API
run healthcheck/k8s-local

## Deploy the upstream rancher local-path-provisioner. k3s's bundled
## local-path is disabled (see k3s/up DISABLE list); labops owns the
## provisioner end-to-end. Idempotent via kubectl apply — repeat runs
## are no-ops.
echo "[ STORAGE/INSTALL ] deploying rancher local-path-provisioner"
mkdir -p /opt/local-path-provisioner
kubectl apply -f https://raw.githubusercontent.com/rancher/local-path-provisioner/master/deploy/local-path-storage.yaml

## Two StorageClasses, reclaim by intent. Both backed by the same
## rancher.io/local-path provisioner — same disk, same shape — but
## different lifecycle contracts:
##   standard   Retain — stateful workloads (postgres, app data,
##                       anything where accidental loss hurts);
##                       MARKED CLUSTER DEFAULT for safe defaulting
##   ephemeral  Delete — caches, scratch, reproducible state;
##                       opt-in via storageClassName: ephemeral
## Note: reclaimPolicy is immutable on existing SCs (kubectl apply
## refuses with "Forbidden"). If a prior-shape SC exists, delete it
## first or accept the apply will no-op on the policy field.
read -r -d '' STORAGECLASSES <<EOF
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: standard
  annotations:
    storageclass.kubernetes.io/is-default-class: "true"
provisioner: rancher.io/local-path
reclaimPolicy: Retain
volumeBindingMode: WaitForFirstConsumer
---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: ephemeral
provisioner: rancher.io/local-path
reclaimPolicy: Delete
volumeBindingMode: WaitForFirstConsumer
EOF

printf '%s\n' "${STORAGECLASSES}"
printf '%s\n' "${STORAGECLASSES}" | kubectl apply -f -

## ensure the 'local-path-static' StorageClass for operator-authored PVs.
## Used by apps that pre-create PVs at stable on-disk paths (e.g.
## honcho/postgres) so destroy/rebuild cycles re-bind to the same volume
## without manual UID patching. No provisioner — PVs are authored, not
## generated. WaitForFirstConsumer preserves node affinity on local: paths.
read -r -d '' LOCALSTATIC <<EOF
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: local-path-static
provisioner: kubernetes.io/no-provisioner
reclaimPolicy: Retain
volumeBindingMode: WaitForFirstConsumer
EOF

printf '%s\n' "${LOCALSTATIC}"
printf '%s\n' "${LOCALSTATIC}" | kubectl apply -f -
