#!/bin/bash
## module: kyverno/install
## purpose: install Kyverno admission controller at the latest release
## inputs:  KUBECONFIG, LABOPS_ROOT, KYVERNO_VERSION (optional pin override)
## needs:   healthcheck/k8s-local

## ── labops module resolver ───────────────────────────────────────────
LABOPS_BASE="${LABOPS_BASE:-https://labops.sh}"
command -v run >/dev/null 2>&1 || run() {
	local module="$1"; shift
	if [[ -n "${LABOPS_ROOT:-}" && -f "${LABOPS_ROOT}/${module}" ]]; then
		bash "${LABOPS_ROOT}/${module}" "$@"
	else
		curl -fsSL "${LABOPS_BASE}/${module}" | bash -s -- "$@"
	fi
}

## wait for the API
run healthcheck/k8s-local

## resolve the Kyverno version (latest release unless pinned via KYVERNO_VERSION)
KYVERNO_VERSION="${KYVERNO_VERSION:-$(curl -fsSL https://api.github.com/repos/kyverno/kyverno/releases/latest \
	| sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -1)}"
if [[ -z "${KYVERNO_VERSION}" ]]; then
	echo "[ KYVERNO/INSTALL ] ERROR: could not resolve latest Kyverno release" 1>&2
	exit 1
fi
echo "[ KYVERNO/INSTALL ] version [ ${KYVERNO_VERSION} ]"

## install Kyverno via the official install manifest
## server-side apply: install.yaml contains CRDs that exceed the client-side
## last-applied-configuration annotation limit (same pattern as argo/install)
kubectl apply --server-side --force-conflicts \
	-f "https://github.com/kyverno/kyverno/releases/download/${KYVERNO_VERSION}/install.yaml"
